---
import Layout from '../../layouts/Layout.astro';
import medicamentos from '../../data/medicamento.json';

export function getStaticPaths() {
  return medicamentos.map(m => ({
    params: { slug: m.slug },
    props: { medicine: m },
  }));
}

const { medicine } = Astro.props;
---
<Layout title={`${medicine.nome} - MediCheck`}>
  <div class="container">
    <div class="header">
      <h1>💊 MediCheck</h1>
      <p>Seu medicamento explicado em linguagem simples</p>
    </div>

    <div class="content">
      <div class="medicine-card" style="animation:slideIn 0.5s ease;">
        <h2>💊 {medicine.nome}</h2>
      </div>

      <div class="section">
        <div class="section-title"><span class="icon">❓</span> Para quê serve?</div>
        <div class="section-content">{medicine.paraQue}</div>
      </div>

      <div class="section">
        <div class="section-title"><span class="icon">⏰</span> Como tomar?</div>
        <div class="section-content">{medicine.comoTomar}</div>
      </div>

      <div class="section">
        <div class="section-title"><span class="icon">😷</span> Efeitos colaterais</div>
        <div class="section-content">{medicine.efeitos}</div>
      </div>

      {medicine.avisos && (
        <div class="warning">
          <strong>⚠️ Aviso Importante:</strong> {medicine.avisos}
        </div>
      )}

      {medicine.interacoes && (
        <div class="danger">
          <strong>🚫 Cuidado com Interações:</strong> {medicine.interacoes}
        </div>
      )}

      <div class="success">
        <strong>💰 Sobre Genérico:</strong> {medicine.generico}
      </div>

      <div class="section">
        <div class="section-title"><span class="icon">💡</span> Dica importante</div>
        <div class="section-content">{medicine.dica}</div>
      </div>

      <div class="disclaimer">
        <strong>⚠️ Aviso Importante:</strong> Este aplicativo fornece informações educacionais apenas. NÃO substitui consulta com médico ou farmacêutico. Se tiver dúvidas, sempre converse com um profissional de saúde. Para emergência: ligue 192 (SAMU) ou procure pronto-socorro.
      </div>

      <a class="btn-reset" href={import.meta.env.BASE_URL}>🔄 Buscar Outro Medicamento</a>
    </div>
  </div>
</Layout>
